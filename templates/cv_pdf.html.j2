<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  {# Reference CV used Adobe Garamond (embedded in PDF). We use EB Garamond from Google Fonts — same classical family, licensed for web/PDF generation. For Adobe's files verbatim, you’d add licensed .otf + @font-face. #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
  <style>
    /* --- CV PDF layout: edit these rules (file: templates/cv_pdf.html.j2) ---
       @page          page margins
       body            base font size & line-height (within paragraphs)
       h2              section titles (font-weight, spacing above/below each section)
       h2:first-of-type   gap under your name before first section
       .pub-entry …    space around each publication / WP / WIP block
       .footer-updated  “Updated …” line
    */
    @page { margin: 0.72in 0.78in; }
    body {
      font-family: 'EB Garamond', Garamond, 'Times New Roman', Times, serif;
      font-size: 9pt;
      line-height: 1.28;
      color: #111;
    }
    h1 {
      font-size: 13pt;
      font-weight: 700;
      margin: 0 0 0.45em 0;
      text-align: center;
      font-family: 'EB Garamond', Garamond, 'Times New Roman', Times, serif;
    }
    /* All caps + tracking read heavier than body even at 400; forbid faux-bold */
    h2 {
      font-size: 9pt;
      font-weight: 400 !important;
      font-synthesis: none;
      font-family: 'EB Garamond', Garamond, 'Times New Roman', Times, serif;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.055em;
      /* margin-top: space between sections (~ +½ body line from prior 1.45em) */
      margin: 2.1em 0 0.48em 0;
      padding-bottom: 0;
      border-bottom: none;
    }
    h2:first-of-type {
      margin-top: 0.92em;
    }
    .contact-block {
      text-align: left;
      margin-bottom: 0.65em;
      font-size: 8.5pt;
    }
    .contact-block .addr { margin: 0.12em 0; }
    .contact-block .email { margin-top: 0.28em; }
    .cv-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1.25em;
      margin: 0.2em 0;
      font-size: inherit;
    }
    .cv-left { flex: 1; min-width: 0; }
    .cv-right {
      flex-shrink: 0;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    .edu-row .cv-edu-left {
      flex: 1;
      min-width: 0;
    }
    .pub-entry, .wp-entry, .wip-entry {
      margin: 0.38em 0 0.52em 0;
    }
    .pub-title, .wp-title, .wip-title {
      font-weight: 600;
    }
    .pub-authors, .wp-authors, .wip-authors {
      margin: 0.12em 0 0 0;
      padding-left: 0;
      font-weight: 400;
    }
    .pub-journal {
      margin: 0.12em 0 0 0;
    }
    .wp-status {
      margin: 0.12em 0 0 0;
      font-style: italic;
      font-weight: 400;
      color: #444;
    }
    .wp-status em {
      font-style: italic;
      font-weight: inherit;
      color: inherit;
    }
    .grant { margin: 0.25em 0; font-size: inherit; }
    a { color: #0b57d0; text-decoration: none; }
    .footer-updated {
      margin-top: 1.35em;
      text-align: center;
      font-size: 7.5pt;
      color: #444;
      font-family: 'EB Garamond', Garamond, 'Times New Roman', Times, serif;
    }
    /* teaching uses .cv-row like education (course left, dates right) */
    em { font-style: italic; font-family: inherit; }
  </style>
</head>
<body>

  <h1>{{ meta.name }}</h1>

{% for sec in sections %}
  <h2>{{ sec.heading }}</h2>

  {% if sec.kind == 'contact' %}
    {% for item in sec.entries %}
    <div class="contact-block">
      {% for line in item.address_lines %}
      <div class="addr">{{ line }}</div>
      {% endfor %}
      {% if item.email %}
      <div class="email"><a href="mailto:{{ item.email }}">{{ item.email }}</a></div>
      {% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'experience' %}
    {% for item in sec.entries %}
    <div class="cv-row">
      <span class="cv-left">{{ item.left }}</span>
      <span class="cv-right">{{ item.right }}</span>
    </div>
    {% endfor %}

  {% elif sec.kind == 'education' %}
    {% for item in sec.entries %}
    <div class="cv-row edu-row">
      <span class="cv-edu-left"><strong>{{ item.degree }}</strong>{% if item.distinction %} {{ item.distinction }}{% endif %}, <em>{{ item.institution }}</em></span>
      <span class="cv-right">{{ item.year }}</span>
    </div>
    {% endfor %}

  {% elif sec.kind == 'publication' %}
    {% for item in sec.entries %}
    <div class="entry pub-entry">
      <div class="pub-title">{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}</div>
      {% if item.coauthors %}<div class="pub-authors">{{ item.coauthors }}</div>{% endif %}
      <div class="pub-journal"><em>{{ item.venue }}</em>, {{ item.year }}.</div>
    </div>
    {% endfor %}

  {% elif sec.kind == 'working_paper' %}
    {% for item in sec.entries %}
    <div class="entry wp-entry">
      <div class="wp-title">{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}</div>
      {% if item.coauthors %}<div class="wp-authors">{{ item.coauthors }}</div>{% endif %}
      {% if item.paper_status %}<div class="wp-status"><em>{{ item.paper_status }}</em></div>{% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'wip' %}
    {% for item in sec.entries %}
    <div class="entry wip-entry">
      <div class="wip-title">{{ item.title }}</div>
      {% if item.coauthors %}<div class="wip-authors">{{ item.coauthors }}</div>{% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'teaching' %}
    {% for item in sec.entries %}
    <div class="cv-row teaching-row">
      <span class="cv-left"><strong>{{ item.course }}</strong></span>
      <span class="cv-right">{{ item.detail }}</span>
    </div>
    {% endfor %}

  {% elif sec.kind == 'grant' %}
    {% for item in sec.entries %}
    <div class="grant">{{ item.text }}</div>
    {% endfor %}

  {% endif %}
{% endfor %}

  <p class="footer-updated">Updated {{ updated_label }}</p>

</body>
</html>
